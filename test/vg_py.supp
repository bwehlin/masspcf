# pybind11 intentionally leaks small amounts during module initialization.
# These are not real leaks in user code.

{
   pybind11_strdup_guard
   Memcheck:Leak
   fun:malloc
   fun:strdup
   fun:_ZN8pybind116*
}

{
   pybind11_argument_record_vector
   Memcheck:Leak
   ...
   fun:_ZN8pybind116detail26append_self_arg_if_neededE*
}

{
   pybind11_initialize_generic
   Memcheck:Leak
   ...
   fun:_ZN8pybind1112cpp_function18initialize_genericE*
}

{
   pybind11_initialize_template
   Memcheck:Leak
   ...
   fun:_ZN8pybind1112cpp_function10initializeI*
}

{
   pybind11_module_init
   Memcheck:Leak
   ...
   fun:pybind11_init__mpcf*
}

# CPython does not free all memory at shutdown by design.
# Extension module init (NumPy, stdlib C modules, etc.) allocates
# persistent state that is never freed.
{
   cpython_module_exec
   Memcheck:Leak
   ...
   fun:PyModule_ExecDef
}

# Interned Unicode strings are intentionally kept alive for the
# lifetime of the interpreter.
{
   cpython_unicode_new
   Memcheck:Leak
   ...
   fun:PyUnicode_New
}
